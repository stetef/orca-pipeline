#!/bin/bash
#SBATCH --partition=milano
#SBATCH --account=ssrl:SMBXAS
#SBATCH --nodes=1
#SBATCH --ntasks=16
#SBATCH --job-name=prep-corvus-[RUN_ID]
#SBATCH --output=prep-corvus-[RUN_ID].sout
#SBATCH --error=prep-corvus-[RUN_ID].serr
#SBATCH --chdir=.

set -euo pipefail

RUN_DIR=[RUN_DIR]
RUN_ID=[RUN_ID]
PREP_CORVUS=[PREP_CORVUS]
export PIPELINE_ROOT=$(cd "$(dirname "$PREP_CORVUS")" && pwd)
if [[ -d "$PIPELINE_ROOT/.venv/bin" ]]; then
  export PATH="$PIPELINE_ROOT/.venv/bin:$PATH"
fi

if [[ -n "${PIPELINE_PYTHON:-}" ]]; then
  PYTHON_BIN="$PIPELINE_PYTHON"
elif [[ -x "$PIPELINE_ROOT/.venv/bin/python" ]]; then
  PYTHON_BIN="$PIPELINE_ROOT/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python)"
else
  echo "No usable Python interpreter found for $PREP_CORVUS" >&2
  exit 127
fi

cd "$RUN_DIR"

start_epoch=$(date +%s)
timing_file="$RUN_DIR/$RUN_ID-corvus.timing"
echo "start_epoch=$start_epoch" > "$timing_file"
echo "hostname=$(hostname)" >> "$timing_file"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] Starting prepare-corvus for $RUN_ID"
echo "Using Python interpreter: $PYTHON_BIN"
"$PYTHON_BIN" --version || true
"$PYTHON_BIN" "$PREP_CORVUS" "$RUN_DIR" --scheduler [SCHEDULER] --num-procs "${SLURM_NTASKS:-16}"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] prepare-corvus complete; running CORVUS for $RUN_ID"
if [[ ! -f "$RUN_DIR/corvus-job.script" ]]; then
  echo "Missing generated corvus-job.script in $RUN_DIR" >&2
  exit 2
fi

# Execute generated corvus script inline (not nested scheduler submission).
# The generated script uses SLURM_SUBMIT_DIR, so point it to this run directory.
# Use bash -l (login shell) so that 'module' is available for load_openmpi.
export SLURM_SUBMIT_DIR="$RUN_DIR"
bash -l "$RUN_DIR/corvus-job.script"

run_status=$?
end_epoch=$(date +%s)
elapsed=$((end_epoch - start_epoch))
echo "end_epoch=$end_epoch" >> "$timing_file"
echo "elapsed_seconds=$elapsed" >> "$timing_file"
echo "exit_code=$run_status" >> "$timing_file"
echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] CORVUS inline script exit code: $run_status"
exit $run_status
