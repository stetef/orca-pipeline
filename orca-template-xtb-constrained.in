! QM/XTB TightOPT PBE0 D3BJ RIJCOSX def2-TZVP def2/J ALPB(water)

# Set high-level region here, everthing else will be low level 
# High level is all coordinating atoms, including CA/N/C/O
%QMMM QMATOMS [INDICES] END END

# Do frequency calculation (produce .hess file)
! AnFreq

! 6-311++G(d,p)
! ZORA ZORA-def2-TZVP SARC/J

%basis
  NewGTO Zn "def2-TZVPP" end
end

# Specify numnber of processors
%pal nprocs 16
  end

# Constrain all atoms not in coordinating residues, and CA/N/C/O in coord
%geom Constraints
    {C [CA_ATOM] C}  # Freeze all coordinates (X, Y, Z) of atom [CA_ATOM]
  end
end

# Use xyz file, first number is charge, second number is multiplicity (2S+1)
*xyzfile [CHARGE] [MULTIPLICITY] [ID_DIR]/[PDB_ID]_clean.xyz